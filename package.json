{
  "name": "irrigation-checkup-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --config jest.config.js",
    "test:db": "DATABASE_URL_TEST=postgresql://localhost:5432/irrigation_test jest --config jest.integration.config.js --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test:migrate": "dropdb --if-exists irrigation_migrate_test 2>/dev/null; createdb irrigation_migrate_test && DATABASE_URL=postgresql://localhost:5432/irrigation_migrate_test npm run db:migrate; ec=$?; dropdb --if-exists irrigation_migrate_test 2>/dev/null; exit $ec"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@clerk/nextjs": "^7.0.7",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@turf/turf": "^7.3.5",
    "drizzle-orm": "^0.45.2",
    "mapbox-gl": "^3.22.0",
    "next": "^15.2.8",
    "postgres": "^3.4.8",
    "puppeteer-core": "^23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.8",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@testcontainers/postgresql": "^11.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
