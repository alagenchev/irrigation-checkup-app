{
  "name": "irrigation-checkup-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest --config jest.config.js",
    "test:db": "DATABASE_URL_TEST=postgresql://localhost:5432/irrigation_test jest --config jest.integration.config.js --runInBand",
    "db:migrate": "ts-node -e \"require('./lib/db').initDb().then(() => { console.log('Migrations complete'); process.exit(0); })\"",
    "db:migrate:test": "ts-node -e \"require('./lib/db').initDb().then(() => { console.log('done'); process.exit(0); })\" -- DATABASE_URL=$DATABASE_URL_TEST"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.7",
    "next": "15.2.4",
    "pg": "^8.20.0",
    "puppeteer-core": "^23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
